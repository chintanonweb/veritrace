{
  "name": "@veritrace/verifier",
  "version": "0.0.1",
  "description": "Independently verify a VeriTrace receipt — no account, no trust in VeriTrace required.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": { ".": "./src/index.ts" },
  "bin": { "veritrace-verify": "./bin/veritrace-verify.mjs" },
  "scripts": {
    "test": "vitest run",
    "verify": "tsx bin/veritrace-verify.mjs"
  },
  "dependencies": {
    "@veritrace/core": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
